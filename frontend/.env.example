# Local dev: leave empty — Vite proxies /api to http://localhost:8000
# Production (Netlify): set to your public backend URL, e.g. https://forensiguard-api.onrender.com
VITE_API_URL=

# OAuth redirect URI used by Google/GitHub consoles (frontend callback):
# Local:  http://localhost:5173/auth/callback
# Netlify: https://your-site.netlify.app/auth/callback
#
# Configure these secrets on the backend (Render / docker-compose), not in the frontend:
# FRONTEND_URL, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET
